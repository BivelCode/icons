/* 
   Font-face declaration
   Defines the custom font family for the current icon style.
   The font is loaded only when needed (font-display: block).
 */

@font-face {
  font-family: "{{ name }}";
  src: {{{ fontSrc }}};
  font-weight: normal;
  font-style: normal;
  font-display: block;
}

/* 
   Base icon class
   Applied to every icon element via the .bc class. It sets
   the font family and normalises typographic properties.
   The selector matches elements whose class attribute starts
   with or contains the style prefix (e.g. "bi-sr-").
 */

{{ tag }}.bc[class^="{{ prefix }}-"]::before,
{{ tag }}.bc[class*=" {{ prefix }}-"]::before {
  font-family: "{{ name }}" !important;
  font-style: normal;
  font-weight: normal;
  font-variant: normal;
  text-transform: none;
  line-height: 1;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

/* Individual icon glyphs
   Each icon is mapped to its Unicode codepoint. The content
   property inserts the corresponding character in the icon's
   pseudo-element.
*/

{{#each codepoints }}
.{{ ../prefix }}-{{ @key }}::before {
  content: "\\{{ codepoint this }}";
}
{{/each }}
